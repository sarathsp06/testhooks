# Testhooks — Environment Variables
# Copy to .env and adjust as needed. All values shown are defaults.

# Listen address for the HTTP server.
LISTEN=:8080

# PORT overrides LISTEN when set (standard PaaS convention: ":<PORT>").
# PORT=

# PostgreSQL connection string.
DATABASE_URL=postgres://testhooks:testhooks@localhost:5432/testhooks?sslmode=disable

# Dev mode: proxy SPA requests to the Vite dev server.
DEV=false

# Vite dev server URL (used when DEV=true).
VITE_URL=http://localhost:5173

# Max body size in bytes for captured webhook requests (default 512KB).
MAX_BODY_SIZE=524288

# Max total body storage in bytes per endpoint — oldest requests are pruned
# when an endpoint exceeds this budget (default 10MB).
MAX_ENDPOINT_STORAGE_BYTES=10485760

# Max requests stored per endpoint — oldest are pruned beyond this count.
MAX_REQUESTS_PER_ENDPOINT=500

# Background pruner interval in seconds.
PRUNE_INTERVAL_SECONDS=60

# Ring buffer size for browser-mode endpoints (in-memory, per endpoint).
RING_BUFFER_SIZE=100

# Rate limit: sustained requests per second per IP on capture endpoints.
# Set to 0 to disable rate limiting.
RATE_LIMIT_RPS=20

# Rate limit: maximum burst size per IP.
RATE_LIMIT_BURST=40
